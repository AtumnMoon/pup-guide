{
	"workspace": ["server", "packages/types", "scripts"],
	"imports": {
		"@mainframe-api/deno-sqlite": "jsr:@mainframe-api/deno-sqlite@^3.9.1",
		"@std/fs": "jsr:@std/fs@^1.0.23",
		"@std/path": "jsr:@std/path@^1.1.4"
	},
	"tasks": {
		"migrate": "deno run --allow-read --allow-write --allow-env server/db/migrate.ts",
		"sync": "deno run --allow-read --allow-write --allow-env scripts/sync-content.ts",
		"dev": "deno task --cwd server dev"
	}
}
