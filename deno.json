{
	"nodeModulesDir": "manual",
	"tasks": {
		"check": "deno fmt --check . && deno lint . && deno check",
		"migrate": "deno run -A db/migrate.ts",
		"dev": "deno task migrate && vite",
		"build": "vite build",
		"start": "deno serve -A _fresh/server.js",
		"update": "deno run -A -r jsr:@fresh/update ."
	},
	"lint": {
		"rules": {
			"tags": ["fresh", "recommended"]
		}
	},
	"exclude": ["**/_fresh/*"],
	"imports": {
		"@/": "./",
		"@deno/gfm": "jsr:@deno/gfm@^0.12.0",
		"@mainframe-api/deno-sqlite": "jsr:@mainframe-api/deno-sqlite@^3.9.1",
		"@std/fs": "jsr:@std/fs@^1.0.23",
		"@std/path": "jsr:@std/path@^1.1.4",
		"@tailwindcss/typography": "npm:@tailwindcss/typography@^0.5.19",
		"daisyui": "npm:daisyui@^5.5.19",
		"fresh": "jsr:@fresh/core@^2.3.3",
		"hash-wasm": "npm:hash-wasm@^4.12.0",
		"preact": "npm:preact@^10.29.1",
		"@preact/signals": "npm:@preact/signals@^2.9.0",
		"@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
		"vite": "npm:vite@^7.1.3",
		"@types/babel__core": "npm:@types/babel__core@^7.20.5",
		"tailwindcss": "npm:tailwindcss@^4.1.10",
		"@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
		"zod": "npm:zod@^4.3.6"
	},
	"compilerOptions": {
		"lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
		"jsx": "precompile",
		"jsxImportSource": "preact",
		"jsxPrecompileSkipElements": [
			"a",
			"img",
			"source",
			"body",
			"html",
			"head",
			"title",
			"meta",
			"script",
			"link",
			"style",
			"base",
			"noscript",
			"template"
		],
		"types": ["vite/client"]
	}
}
